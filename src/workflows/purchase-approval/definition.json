{
  "id": "purchase-approval",
  "name": "Bestellung / Freigabe",
  "description": "Bestellungen zur Freigabe einreichen",
  "icon": "🛒",
  "roles": ["employee", "manager"],
  "form": {
    "fields": [
      { "id": "supplier",    "label": "Lieferant",    "type": "text",     "required": true  },
      { "id": "description", "label": "Beschreibung", "type": "textarea", "required": true  },
      { "id": "amount",      "label": "Betrag (€)",    "type": "number",   "required": true, "min": 0, "step": "0.01" },
      { "id": "cost_center", "label": "Kostenstelle", "type": "text",     "required": false }
    ]
  },
  "steps": [
    { "id": "submit",           "type": "form",     "actor": "submitter", "onApprove": "notify-manager"    },
    { "id": "notify-manager",   "type": "action",   "actor": "system",    "action": "notify-manager",   "onApprove": "manager-approval" },
    { "id": "manager-approval", "type": "approval", "actor": "manager",   "onApprove": "notify-approved", "onReject": "notify-rejected"  },
    { "id": "notify-approved",  "type": "action",   "actor": "system",    "action": "notify-approved",  "onApprove": "done" },
    { "id": "notify-rejected",  "type": "action",   "actor": "system",    "action": "notify-rejected",  "onApprove": "done" }
  ]
}
